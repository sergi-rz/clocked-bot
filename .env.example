# ── Required ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id

# ── Optional (bot-level) ────────────────────────────────────────────────────
# Baked into slash command names at deploy time. Same prefix for all guilds
# this bot instance serves.
COMMAND_PREFIX=deepwork

# Reconciliation poll interval (ms). Catches events missed while the bot was down.
POLL_INTERVAL_MS=1800000

# Sessions shorter than this are excluded from stats and rankings.
MIN_SESSION_MINUTES=5

# ── Defaults for new guilds ─────────────────────────────────────────────────
# When a server admin runs /setup for the first time, these are the initial
# values for their guild config. Each guild can override them afterwards
# via /{PREFIX}-setup config. They also drive the slash command
# descriptions (which are global and cannot be localized per guild).
DEFAULT_ACTIVITY_NAME=Deep Work
DEFAULT_LOCALE=es
DEFAULT_TIMEZONE=Europe/Madrid
DEFAULT_SUMMARY_HOUR=9

# ── Self-host single-guild seed (optional) ──────────────────────────────────
# If you're running the bot for just one server and don't want to use /setup,
# set these two vars and the bot will seed its config on first startup.
# Leave them blank if you prefer to configure every guild through /setup.
GUILD_ID=
VOICE_CHANNEL_IDS=

# ── Development ─────────────────────────────────────────────────────────────
# Commands register globally by default (up to 1h propagation). Setting this
# registers them to a single guild instead, which is instant — handy in dev.
# DEV_GUILD_ID=
